{
  "name": "@gladysassistant/integration-sdk",
  "version": "0.6.1",
  "description": "Official Node.js SDK to build external integrations for Gladys Assistant",
  "main": "lib/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./esm/index.mjs",
      "require": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "esm",
    "index.d.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint .",
    "prettier-check": "prettier --check '**/*.{js,mjs,ts,json,md,yml}'",
    "prettier": "prettier --write '**/*.{js,mjs,ts,json,md,yml}'",
    "check-types": "tsc -p tsconfig.json",
    "test": "node --test test/*.test.js",
    "coverage": "c8 node --test test/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GladysAssistant/integration-sdk-js.git"
  },
  "keywords": [
    "gladys",
    "gladys-assistant",
    "home-automation",
    "integration",
    "sdk"
  ],
  "author": "Gladys Assistant",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/GladysAssistant/integration-sdk-js/issues"
  },
  "homepage": "https://github.com/GladysAssistant/integration-sdk-js#readme",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "c8": "^11.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  }
}
