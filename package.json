{
  "name": "@gladysassistant/integration-sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK to build external integrations for Gladys Assistant",
  "main": "lib/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./esm/index.mjs",
      "require": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "esm",
    "index.d.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint lib test",
    "prettier-check": "prettier --check '**/*.{js,mjs,ts,json,md,yml}'",
    "prettier": "prettier --write '**/*.{js,mjs,ts,json,md,yml}'",
    "check-types": "tsc -p tsconfig.json",
    "test": "mocha",
    "coverage": "c8 mocha"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GladysAssistant/integration-sdk-js.git"
  },
  "keywords": [
    "gladys",
    "gladys-assistant",
    "home-automation",
    "integration",
    "sdk"
  ],
  "author": "Gladys Assistant",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/GladysAssistant/integration-sdk-js/issues"
  },
  "homepage": "https://github.com/GladysAssistant/integration-sdk-js#readme",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "c8": "^10.1.2",
    "chai": "^4.5.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "mocha": "^10.8.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
